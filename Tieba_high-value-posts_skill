  需要先导航到帖子详情页。

  Step 1: 导航到目标帖子详情页
    https://tieba.baidu.com/p/{thread_id}
    等待页面完全加载

  Step 2: 通过 Vue 实例调用加精

    在浏览器中执行 JavaScript：

    (function() {
      // 定位主楼的 more-action 按钮
      var moreBtn = document.querySelector(
        '.action-bar-container.action-bar .more-action'
      );
      if (!moreBtn) return { success: false, error: 'more-action not found' };

      // 向上遍历找到 Vue 实例
      var el = moreBtn;
      while (el && el.tagName !== 'BODY') {
        if (el.__vue__) {
          var parent = el.__vue__.$parent;
          if (parent && typeof parent.permissionClick === 'function') {
            // 确认 permissionList 中包含 'good'
            var hasGood = parent.permissionList && 
              parent.permissionList.some(item => item.action === 'good');
            if (hasGood) {
              parent.permissionClick('good');
              return { success: true, method: 'permissionClick' };
            } else {
              return { success: false, error: 'no good permission' };
            }
          }
          break;
        }
        el = el.parentElement;
      }
      return { success: false, error: 'Vue instance not found' };
    })();

